# ──────────────────────────────────────────────────
# VideoSeal Watcher Service — environment variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────

# ── Folder paths (set these to your actual host paths) ───────────────────────

# Folder to watch — new videos placed here will be watermarked (READ-ONLY, never modified)
INPUT_FOLDER=/absolute/path/to/your/input/videos

# Folder where watermarked output videos are saved
OUTPUT_FOLDER=/absolute/path/to/your/output/videos

# Host folder for DB + error.log (created automatically if missing)
DATA_DIR=./data/db

# ── Internal container paths (usually no need to change) ─────────────────────
DB_PATH=/data/watermarks.db
ERROR_LOG=/data/error.log

# Fixed watermark text embedded in every video.
# Leave empty to generate a random UUID per file.
WATERMARK_TEXT=

# Path to your trained VideoSeal checkpoint.
# Relative paths are resolved from the project root.
CUSTOM_CKPT_PATH=output/run2_video/checkpoint350.pth

# Compute device: "cuda" (recommended) or "cpu"
DEVICE=cuda

# Whether to watermark files already present in INPUT_FOLDER at startup.
# Set to "false" if you only want to process new arrivals.
SCAN_EXISTING=true

# ── GPU tuning (thay đổi không cần rebuild, chỉ cần restart) ─────────────────

# GPU index sử dụng. Mặc định dùng GPU 0. Đặt "-1" để force CPU.
CUDA_VISIBLE_DEVICES=0

# Số frame xử lý mỗi batch GPU.
# Tăng → dùng nhiều VRAM hơn, nhanh hơn. Giảm nếu bị OOM.
# Gợi ý: 8GB VRAM → 60-90, 12GB → 120, 24GB → 240
CHUNK_SIZE=30

# Phần trăm VRAM tối đa service được dùng [0.1 – 1.0].
# 0.9 = 90% VRAM. Giảm xuống nếu muốn chừa VRAM cho ứng dụng khác.
GPU_MEMORY_FRACTION=0.9

# Số worker thread xử lý song song. Mỗi worker xử lý 1 video cùng lúc.
# Tăng → xử lý nhiều video cùng lúc, nhưng tốn VRAM gấp bội.
# Gợi ý: 16GB VRAM, CHUNK_SIZE=10 → NUM_WORKERS=2
NUM_WORKERS=1

# ── Logging & Stats ────────────────────────────────────────────────────────────

# File CSV ghi stats mỗi video (thời gian, GPU, throughput).
# Để trống = không ghi. Dùng để visualize hiệu suất.
STATS_CSV=/data/stats.csv
